// https://zed.dev/docs/configuring-zed
{
  "agent": {
    "flexible": true,
    "sidebar_side": "left",
    "dock": "left",
    "commit_message_model": {
      "model": "claude-haiku-4.5",
      "provider": "copilot_chat",
    },
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "model": "claude-sonnet-4.6",
      "provider": "copilot_chat",
    },
    "default_profile": "ask",
    "favorite_models": [
      { "model": "claude-opus-4.6", "provider": "copilot_chat" },
      { "model": "claude-sonnet-4.6", "provider": "copilot_chat" },
      { "model": "claude-haiku-4.5", "provider": "copilot_chat" },
    ],
    "inline_assistant_model": {
      "model": "claude-sonnet-4.6",
      "provider": "copilot_chat",
      "enable_thinking": false,
    },
    "tool_permissions": {
      "tools": {
        "fetch": { "default": "allow" },
        "terminal": {
          "default": "confirm",
          "always_allow": [
            { "pattern": "^cargo\\s+(build|test|check|clippy|fmt)" },
            { "pattern": "^(p?npm|bun)\\s+(install|test|run|build|update)" },
            { "pattern": "^git\\s+(status|log|diff|branch|pull)" },
            {
              "pattern": "^(ls|cat|pwd|echo|which|find|grep|tree|test|head|tail|wc)\\b",
            },
          ],
          "always_deny": [
            { "pattern": "rm\\s+-rf\\s+(/|~)" },
            { "pattern": "sudo\\b" },
          ],
        },
      },
    },
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "auto_install_extensions": {
    "catppuccin-icons": true,
    "emmet": true,
    "git-firefly": true,
    "html": true,
    "toml": true,
  },
  "buffer_font_family": "0xProto Nerd Font",
  "buffer_font_features": { "calt": false, "ss01": false },
  "buffer_font_size": 14,
  "buffer_line_height": { "custom": 2.1 },
  "collaboration_panel": { "dock": "right", "button": false },
  "colorize_brackets": false,
  "current_line_highlight": "all",
  "disable_ai": false,
  "double_click_in_multibuffer": "select",
  "edit_predictions": {
    "copilot": {
      "enable_next_edit_suggestions": true,
      "enterprise_uri": null,
      "proxy": null,
      "proxy_no_verify": null,
    },
    "provider": "copilot",
    "mode": "subtle",
  },
  "ensure_final_newline_on_save": true,
  "git": { "inline_blame": { "enabled": false } },
  "git_panel": {
    "dock": "right",
    "sort_by_path": false,
    "tree_view": false,
  },
  "hidden_files": [
    "**/*-lock*",
    "**/*.class",
    "**/*.egg*",
    "**/*.env",
    "**/*.lock*",
    "**/*.log",
    "**/*.tsbuildinfo",
    "**/*env.d.ts",
    "**/artisan",
    "**/azure*yml",
    "**/build",
    "**/bunfig.toml",
    "**/Cargo.lock",
    "**/coverage",
    "**/dist",
    "**/LICENSE*",
    "**/node_modules",
    "**/phpunit.xml",
    "**/pnpm-lock*",
    "**/target",
    "**/tsconfig.*",
    "**/vendor",
    "**/venv",
    ".*",
    "/__*",
    "/sentry*",
  ],
  "icon_theme": {
    "dark": "Catppuccin Mocha",
    "light": "Catppuccin Latte",
    "mode": "system",
  },
  "indent_guides": { "enabled": true },
  "inline_code_actions": false,
  "languages": {
    "TypeScript": { "language_servers": ["vtsls"] },
    "JavaScript": { "language_servers": ["vtsls"] },
  },
  "language_models": {
    "ollama": { "api_url": "http://10.0.10.0:11434" },
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
          "tsserver": {
            "experimental": {
              "enableProjectDiagnostics": true,
            },
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
  "outline_panel": {
    "dock": "right",
  },
  "profiles": {
    "Focus": {
      "settings": {
        "buffer_font_size": 18,
        "current_line_highlight": "none",
        "gutter": {
          "breakpoints": false,
          "folds": false,
          "line_numbers": false,
          "min_line_number_digits": 0,
          "runnables": false,
        },
        "indent_guides": {
          "enabled": false,
        },
        "scrollbar": {
          "cursors": false,
          "diagnostics": "none",
          "git_diff": false,
          "search_results": false,
          "selected_symbol": false,
          "show": "never",
        },
        "tab_bar": {
          "show": false,
        },
        "toolbar": {
          "breadcrumbs": false,
          "quick_actions": false,
        },
      },
    },
    "Sharing": {
      "settings": {
        "buffer_font_size": 26,
        "project_panel": {
          "indent_size": 20,
        },
        "ui_font_size": 26,
      },
    },
  },
  "project_panel": {
    "auto_fold_dirs": false,
    "diagnostic_badges": true,
    "dock": "right",
    "entry_spacing": "comfortable",
    "folder_icons": true,
    "git_status": true,
    "git_status_indicator": false,
    "hide_hidden": false,
    "hide_root": false,
    "indent_size": 16,
    "show_diagnostics": "off",
  },
  "remove_trailing_whitespace_on_save": true,
  "scrollbar": {
    "cursors": false,
    "git_diff": false,
  },
  "search": { "button": false },
  "session": { "trust_all_worktrees": true },
  "show_edit_predictions": false,
  "ssh_connections": [
    {
      "args": [],
      "host": "axo",
      "projects": [{ "paths": ["/home/zak"] }],
      "username": "zak",
    },
  ],
  "sticky_scroll": { "enabled": true },
  "tab_bar": { "show_nav_history_buttons": false },
  "tabs": {
    "activate_on_close": "neighbour",
    "close_position": "right",
    "file_icons": true,
    "git_status": true,
  },
  "telemetry": { "diagnostics": false, "metrics": false },
  "terminal": {
    "toolbar": { "breadcrumbs": false },
    "line_height": { "custom": 1.6 },
    "shell": { "program": "nu" },
  },
  "theme": {
    "dark": "Claude Dark",
    "light": "Claude Light",
    "mode": "system",
  },
  "theme_overrides": {
    "One Dark": {
      "syntax": {
        "comment": { "font_style": "italic" },
        "comment.doc": { "font_style": "italic" },
      },
    },
    "One Light": {
      "syntax": {
        "comment": { "font_style": "italic" },
        "comment.doc": { "font_style": "italic" },
      },
    },
  },
  "title_bar": {
    "show_sign_in": false,
    "show_user_picture": false,
  },
  "ui_font_family": ".ZedSans",
  "ui_font_size": 16,
  "vertical_scroll_margin": 6,
  "vim": { "toggle_relative_line_numbers": true },
  "vim_mode": false,
}
