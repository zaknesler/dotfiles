// https://zed.dev/docs/configuring-zed
{
  "$schema": "zed://schemas/settings",
  "agent": {
    "flexible": true,
    "sidebar_side": "left",
    "dock": "left",
    "commit_message_model": {
      "model": "claude-haiku-4-5",
      "provider": "zed.dev",
    },
    "default_model": {
      "effort": "low",
      "enable_thinking": true,
      "model": "claude-sonnet-4-6",
      "provider": "zed.dev",
    },
    "default_profile": "write",
    "inline_assistant_model": {
      "model": "claude-sonnet-4-6",
      "provider": "zed.dev",
      "enable_thinking": false,
      "effort": "low",
    },
    "tool_permissions": {
      "tools": {
        "fetch": { "default": "allow" },
        "terminal": {
          "default": "confirm",
          "always_allow": [
            {
              "pattern": "^cargo\\s+(build|test|check|clippy|fmt)",
            },
            {
              "pattern": "^p?npm\\s+(install|test|run|build|update)",
            },
            {
              "pattern": "^git\\s+(status|log|diff|branch|pull)",
            },
            {
              "pattern": "^(ls|cat|pwd|echo|which|find|grep|tree|test|head|tail|wc)\\b",
            },
          ],
          "always_deny": [
            { "pattern": "rm\\s+-rf\\s+(/|~)" },
            { "pattern": "sudo\\b" },
          ],
        },
      },
    },
  },
  "auto_install_extensions": {
    "catppuccin-icons": true,
    "emmet": true,
    "git-firefly": true,
    "html": true,
    "toml": true,
  },
  "buffer_font_family": "0xProto Nerd Font",
  "buffer_font_features": { "calt": false, "ss01": false },
  "buffer_font_size": 14,
  "buffer_line_height": { "custom": 2.1 },
  "cli_default_open_behavior": "new_window",
  "code_lens": "menu",
  "collaboration_panel": { "dock": "right", "button": false },
  "colorize_brackets": false,
  "completion_detail_alignment": "left",
  "current_line_highlight": "all",
  "diff_view_style": "split",
  "disable_ai": false,
  "double_click_in_multibuffer": "select",
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
    "allow_data_collection": "no",
  },
  "ensure_final_newline_on_save": true,
  "git": { "inline_blame": { "enabled": false } },
  "git_panel": {
    "dock": "right",
    "sort_by_path": false,
    "tree_view": false,
  },
  "hidden_files": [
    "**/*-lock*",
    "**/*.class",
    "**/*.egg*",
    "**/*.env",
    "**/*.lock*",
    "**/*.log",
    "**/*.tsbuildinfo",
    "**/*env.d.ts",
    "**/artisan",
    "**/azure*yml",
    "**/build",
    "**/bunfig.toml",
    "**/Cargo.lock",
    "**/coverage",
    "**/dist",
    "**/LICENSE*",
    "**/node_modules",
    "**/phpunit.xml",
    "**/pnpm-lock*",
    "**/target",
    "**/tsconfig.*",
    "**/vendor",
    "**/venv",
    ".*",
    "/__*",
    "/sentry*",
  ],
  "icon_theme": {
    "dark": "Catppuccin Mocha",
    "light": "Catppuccin Latte",
    "mode": "system",
  },
  "indent_guides": { "enabled": true },
  "inline_code_actions": false,
  "languages": {
    "TypeScript": { "language_servers": ["tsgo"] },
    "JavaScript": { "language_servers": ["tsgo"] },
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
          "tsserver": {
            "experimental": {
              "enableProjectDiagnostics": true,
            },
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
  // "markdown_preview": {
  //   "max_width": 800,
  //   "limit_content_width": true
  // },
  // "markdown_preview_font_family": "PT Serif",
  // "markdown_preview_font_size": 16,
  "outline_panel": { "dock": "right" },
  "profiles": {
    "Large": {
      "settings": {
        "agent_buffer_font_size": 15,
        "buffer_font_size": 15,
        "git_commit_buffer_font_size": 15,
        "project_panel": { "indent_size": 20 },
        "ui_font_size": 18,
      },
    },
    "Larger": {
      "settings": {
        "agent_buffer_font_size": 18,
        "buffer_font_size": 18,
        "git_commit_buffer_font_size": 18,
        "project_panel": { "indent_size": 24 },
        "ui_font_size": 20,
      },
    },
    "Largest": {
      "settings": {
        "agent_buffer_font_size": 20,
        "buffer_font_size": 24,
        "git_commit_buffer_font_size": 20,
        "project_panel": { "indent_size": 24 },
        "ui_font_size": 24,
      },
    },
    "Reading": {
      "settings": {
        "agent_buffer_font_size": 18,
        "buffer_font_size": 18,
        "current_line_highlight": "none",
        "git": { "git_gutter": "hide" },
        "git_commit_buffer_font_size": 18,
        "gutter": {
          "breakpoints": false,
          "folds": false,
          "min_line_number_digits": 0,
          "runnables": false,
          "line_numbers": false,
        },
        "indent_guides": { "enabled": false },
        "project_panel": { "indent_size": 24, "starts_open": false },
        "scrollbar": { "show": "never" },
        "sticky_scroll": { "enabled": false },
        "tab_bar": { "show": false },
        "toolbar": { "breadcrumbs": false, "quick_actions": false },
        "ui_font_size": 20,
      },
    },
  },
  "project_panel": {
    "auto_fold_dirs": false,
    "diagnostic_badges": true,
    "dock": "right",
    "entry_spacing": "comfortable",
    "folder_icons": true,
    "git_status": true,
    "git_status_indicator": false,
    "hide_hidden": true,
    "hide_root": false,
    "indent_size": 16,
    "show_diagnostics": "off",
  },
  "remove_trailing_whitespace_on_save": true,
  "scrollbar": {
    "cursors": false,
    "git_diff": false,
  },
  "search": { "button": false },
  "session": { "trust_all_worktrees": true },
  "show_edit_predictions": false,
  "ssh_connections": [
    {
      "args": [],
      "host": "axo",
      "projects": [{ "paths": ["/home/zak"] }],
      "username": "zak",
    },
  ],
  "sticky_scroll": { "enabled": true },
  "tab_bar": { "show_nav_history_buttons": false },
  "tabs": {
    "activate_on_close": "neighbour",
    "close_position": "right",
    "file_icons": true,
    "git_status": true,
  },
  "telemetry": { "diagnostics": false, "metrics": false },
  "terminal": {
    "toolbar": { "breadcrumbs": false },
    "line_height": { "custom": 1.6 },
    "shell": { "program": "nu" },
  },
  "theme": {
    "dark": "Claude Dimmed",
    "light": "Claude Light",
    "mode": "system",
  },
  "theme_overrides": {
    "One Dark": {
      "syntax": {
        "comment": { "font_style": "italic" },
        "comment.doc": { "font_style": "italic" },
      },
    },
    "One Light": {
      "syntax": {
        "comment": { "font_style": "italic" },
        "comment.doc": { "font_style": "italic" },
      },
    },
  },
  "title_bar": {
    "show_sign_in": false,
    "show_user_picture": false,
  },
  "ui_font_family": ".ZedSans",
  "ui_font_size": 16,
  "vertical_scroll_margin": 6,
  "vim": { "toggle_relative_line_numbers": true },
  "vim_mode": false,
}
