// https://zed.dev/docs/key-bindings
[
  {
    "context": "Workspace",
    "bindings": {
      "cmd-shift-d": null,
      "ctrl-shift-d": null,
      "ctrl-tab": "pane::ActivateNextItem",
      "ctrl-shift-tab": "pane::ActivatePreviousItem",
      "ctrl-alt-win-c": "workspace::ToggleCenteredLayout",
      "cmd-shift-g": "git_panel::ToggleFocus",
      "ctrl-}": "window::ShowNextWindowTab",
      "ctrl-{": "window::ShowPreviousWindowTab",
      "alt-`": "workspace::NewCenterTerminal",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-shift-d": "editor::DuplicateSelection",
      "ctrl-shift-d": "editor::DuplicateSelection",
      "cmd-;": null,
    },
  },
  {
    "context": "(Editor && mode == full)",
    "bindings": {
      "alt-z": "editor::ToggleSoftWrap",
    },
  },
  {
    "context": "Pane",
    "bindings": {
      "cmd-shift-alt-f": "workspace::NewSearch",
    },
  },
  {
    "bindings": {
      "ctrl-alt-c": "project_panel::CollapseAllEntries",
      "alt-cmd-c": "project_panel::CollapseAllEntries",
      "ctrl-alt-v": "project_panel::ToggleHideHidden",
      "alt-cmd-v": "project_panel::ToggleHideHidden",
      "alt-cmd-i": null,
    },
  },
  {
    "context": "Pane",
    "unbind": {
      "cmd-g": "search::SelectNextMatch",
      "cmd-shift-g": "search::SelectPreviousMatch",
    },
  },
]
